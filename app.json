{
  "expo": {
    "name": "Vibly",
    "slug": "vibly",
    "version": "1.0.0",
    "scheme": "vibly",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#F5F3FF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.vibly.mobile",
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.506939484809-5b9mm794vt3hhdo5p95qho4ksi7gstv8"
            ]
          }
        ],
        "NSPhotoLibraryUsageDescription": "프로필 사진을 변경하려면 사진 접근 권한이 필요합니다.",
        "NSCameraUsageDescription": "프로필 사진 촬영을 위해 카메라 접근 권한이 필요합니다.",
        "UIBackgroundModes": [
          "remote-notification",
          "fetch"
        ]
      }
    },
    "android": {
      "package": "com.vibly.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#7C3AED"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-dev-client",
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F5F3FF"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Vibly가 주변 장소를 추천하기 위해 위치 정보가 필요합니다."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#7C3AED"
        }
      ],
      "expo-web-browser",
      [
        "@react-native-seoul/kakao-login",
        {
          "kakaoAppKey": "ac833c12281b79a59bbe05f0f44ecd4c"
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "iosAppId": "ca-app-pub-4793069997129951~7979584137",
          "androidAppId": "ca-app-pub-4793069997129951~3151451796"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "477b6705-c13e-421c-b5be-7527810f44e8"
      },
      "router": {}
    },
    "owner": "kor-giseong"
  }
}
