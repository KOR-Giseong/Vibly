{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      }
    },
    "testflight": {
      "env": {
        "EXPO_PUBLIC_APP_ENV": "testflight"
      },
      "ios": {
        "image": "latest"
      }
    },
    "production": {
      "env": {
        "EXPO_PUBLIC_APP_ENV": "production"
      },
      "autoIncrement": true,
      "ios": {
        "image": "latest"
      },
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "testflight": {
      "ios": {
        "appleId": "ghdrltjd2441@daum.net",
        "ascAppId": "6760162680",
        "appleTeamId": "2TAGX4RN98"
      }
    },
    "production": {
      "ios": {
        "appleId": "ghdrltjd2441@daum.net",
        "ascAppId": "6760162680",
        "appleTeamId": "2TAGX4RN98"
      }
    }
  }
}
